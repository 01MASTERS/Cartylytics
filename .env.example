# Cartlytics – Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=cartlytics_user
DB_PASSWORD=your_strong_password_here
DB_NAME=cartlytics

# ── FastAPI ───────────────────────────────────────────────────
DEBUG=false

# ── Frontend (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
